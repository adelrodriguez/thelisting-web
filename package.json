{
  "name": "thelisting",
  "author": {
    "name": "The Listing",
    "email": "hola@thelisting.do"
  },
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build:css": "npm run generate:css -- --minify",
    "build:db": "npm run database:deploy && npm run database:generate",
    "build:jobs": "tsc --project tsconfig.jobs.json && tsc-alias -p tsconfig.jobs.json",
    "build:remix": "remix build",
    "build": "run-s build:*",
    "clean": "rimraf build lib",
    "database:deploy": "prisma migrate deploy",
    "database:generate": "prisma generate",
    "database:introspect": "prisma db pull",
    "database:prototype": "prisma db push",
    "database:migration:create": "prisma migrate dev --name",
    "database:migration:reset": "prisma migrate reset",
    "database:migration": "prisma migrate dev",
    "deploy": "railway up",
    "dev:css": "npm run generate:css -- --watch",
    "dev:jobs": "cross-env NODE_ENV=development tsx watch jobs/index.ts",
    "dev:remix": "remix dev",
    "dev": "run-p dev:*",
    "docker:start": "docker compose up -d",
    "docker:stop": "docker compose stop",
    "generate:css": "tailwindcss -o app/styles/tailwind.css",
    "lint": "eslint .",
    "logs": "railway logs",
    "start": "remix-serve build",
    "start:jobs": "cross-env NODE_ENV=production node lib/jobs",
    "test:coverage": "vitest run --coverage",
    "test:playwright": "playwright test",
    "generate:shopify:watch": "npm run generate:shopify -- --watch",
    "generate:shopify": "DOTENV_CONFIG_PATH=.env graphql-codegen -r dotenv/config  --config app/services/shopify/codegen.ts",
    "test": "vitest",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@bull-board/express": "4.11.0",
    "@headlessui/react": "^1.7.7",
    "@heroicons/react": "^2.0.13",
    "@prisma/client": "4.9.0",
    "@remix-run/node": "1.10.0",
    "@remix-run/react": "1.10.0",
    "@remix-run/serve": "1.10.0",
    "@remix-validated-form/with-zod": "^2.0.5",
    "@sendgrid/mail": "^7.7.0",
    "@sentry/remix": "^7.28.1",
    "@shopify/storefront-kit-react": "^2023.1.3",
    "@tanstack/react-query": "^4.22.0",
    "@tanstack/react-query-devtools": "^4.22.0",
    "@tanstack/react-table": "^8.7.4",
    "@xstate/inspect": "^0.7.0",
