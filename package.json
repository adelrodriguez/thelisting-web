  "devDependencies": {
    "@anatine/zod-mock": "^3.8.0",
    "@faker-js/faker": "^7.6.0",
    "@graphql-codegen/cli": "^2.16.4",
    "@graphql-codegen/client-preset": "^1.2.6",
    "@headlessui/tailwindcss": "^0.1.2",
    "@playwright/test": "^1.29.0",
    "@railway/cli": "^2.0.13",
