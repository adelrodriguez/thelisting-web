{
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build:css": "npm run generate:css -- --minify",
    "build:remix": "remix build",
    "build": "run-s build:*",
    "database:start": "docker compose up -d",
    "database:stop": "docker compose stop",
    "database:introspect": "prisma db pull",
    "database:migrate": "prisma migrate dev",
    "database:migrate:create": "prisma migrate dev --name",
    "database:migrate:reset": "prisma migrate reset",
    "database:deploy": "prisma migrate deploy",
    "deploy": "railway up",
    "dev:css": "npm run generate:css -- --watch",
    "dev:remix": "remix dev",
    "dev": "run-p dev:*",
    "generate:css": "tailwindcss -o app/styles/tailwind.css",
    "logs": "railway logs",
    "start": "npm run database:deploy && remix-serve build",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@heroicons/react": "^2.0.13",
    "@prisma/client": "^4.7.1",
    "@remix-run/node": "^1.9.0",
    "@remix-run/react": "^1.9.0",
    "@remix-run/serve": "^1.9.0",
    "isbot": "^3.6.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@headlessui/tailwindcss": "^0.1.2",
    "@railway/cli": "^2.0.13",
    "@remix-run/dev": "^1.9.0",
    "@remix-run/eslint-config": "^1.9.0",
    "@tailwindcss/forms": "^0.5.3",
    "@trivago/prettier-plugin-sort-imports": "^4.0.0",
    "@types/react": "^18.0.25",
    "@types/react-dom": "^18.0.8",
    "autoprefixer": "^10.4.13",
    "eslint": "^8.27.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-sort-keys": "^2.3.5",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.20",
    "prettier": "^2.8.1",
    "prisma": "^4.7.1",
    "tailwindcss": "^3.2.4",
    "typescript": "^4.8.4"
  },
  "engines": {
    "node": "18"
  }
}
