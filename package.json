    "currency.js": "^2.0.4",
    "date-fns": "2.29.3",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-basic-auth": "^1.2.1",
    "graphql": "^16.6.0",
    "graphql-request": "^5.1.0",
    "http-status-codes": "^2.2.0",
    "ioredis": "^5.2.4",
    "isbot": "^3.6.5",
    "notistack": "^3.0.0-alpha.11",
    "papaparse": "^5.3.2",
    "playwright": "^1.29.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-number-format": "^5.1.2",
    "remix-auth": "^3.4.0",
    "remix-auth-email-link": "^1.5.0",
    "remix-image": "^1.4.0",
    "remix-typedjson": "^0.1.7",
    "remix-validated-form": "^4.6.5",
    "resend": "^0.10.0",
