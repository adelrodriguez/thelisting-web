    "lint": "eslint .",
    "logs": "railway logs",
    "postinstall": "npx playwright install --with-deps chromium",
    "start": "npm run database:deploy && remix-serve build",
    "test:coverage": "vitest run --coverage",
    "test:playwright": "playwright test",
    "test": "vitest",
    "typecheck": "tsc -b"
