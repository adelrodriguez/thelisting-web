{
  "name": "thelisting",
  "author": {
    "name": "The Listing",
    "email": "admin@thelisting.do"
  },
  "private": true,
  "sideEffects": false,
  "scripts": {
    "build:app": "remix build",
    "build:server": "esbuild --platform=node --format=cjs ./server/index.ts --outfile=./build/server.js --bundle --external:fsevents",
    "build": "run-s build:server build:app database:deploy",
    "clean": "rimraf build lib",
    "database:deploy": "prisma migrate deploy",
    "database:introspect": "prisma db pull",
    "database:migration:create": "prisma migrate dev --name",
    "database:migration:reset": "prisma migrate reset",
    "database:migration": "prisma migrate dev",
    "database:prototype": "prisma db push",
    "deploy": "railway up",
    "dev:app": "remix dev --manual -c 'node ./build/server.js'",
    "dev:server": "cross-env NODE_ENV=development npm run build:server -- --watch",
    "dev": "run-p dev:*",
    "docker:start": "docker compose up -d",
    "docker:stop": "docker compose stop",
    "format": "prettier --write .",
    "generate:database": "prisma generate",
    "generate:routes": "routes-gen -d @routes-gen/remix",
    "generate:scraper:product": "hygen product-scraper new --name",
    "generate:shopify:watch": "npm run generate:shopify -- --watch",
    "generate:shopify": "DOTENV_CONFIG_PATH=.env graphql-codegen -r dotenv/config  --config app/services/shopify/codegen.ts",
    "lint": "eslint .",
    "logs": "railway logs",
    "migrate": "ts-node ./scripts/data-migration/index.ts",
    "postinstall": "run-p generate:*",
    "prebuild": "run-s clean generate:shopify",
    "serve": "cross-env NODE_ENV=production node ./build/server.js",
    "start": "run-s serve",
    "test:coverage": "vitest run --coverage",
    "test:playwright": "playwright test",
    "test": "vitest",
    "typecheck": "tsc -b"
  },
