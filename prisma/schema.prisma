generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  closedAt    DateTime?
  publishedAt DateTime?

  sku        Int     @default(autoincrement())
  commerceId String? @db.VarChar(255)

  eventDate DateTime
  path      String        @unique @db.VarChar(255)
  status    ListingStatus @default(Draft)
  title     String        @db.VarChar(255)

  items Item[]
}

enum ListingStatus {
  Draft
  Published
  Closed
}

model Item {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  commerceId String? @db.VarChar(255)

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String  @db.Uuid

  title       String
  description String?

  quantity  Int @default(0)
  available Int @default(0)
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  firstName String
  lastName  String
  email     String @unique

  role        UserRole  @default(User)
  lastLoginAt DateTime?
}

enum UserRole {
  Admin
  User
}

model ScrapedProduct {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  url String

  time     Float
  duration Float
  errors   String[]

  title       String?
  store       String?
  description String?
  image       String?
  amount      Float?
  currency    String?
}
