generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  closedAt    DateTime?
  publishedAt DateTime?

  sku        Int     @unique @default(autoincrement())
  commerceId String? @db.VarChar(255)

  eventDate DateTime
  path      String        @unique @db.VarChar(255)
  status    ListingStatus @default(Draft)
  title     String        @db.VarChar(255)
  subtitle  String?       @db.VarChar(255)
  type      ListingType   @default(Wedding)

  owner   User   @relation(fields: [ownerId], references: [id])
  ownerId String @db.Uuid

  coverImage    String?
  thankYouImage String?

  redirectUrl String?

  theme Json @default("{}") @db.Json

  items     Item[]
  purchases Purchase[]
  notes     Note[]
  ribbons   Ribbon[]

  // Internal Listings are used to showcase the platform, and shouldn't be
  // accounted for in the analytics
  isInternal Boolean @default(false)
}

enum ListingType {
  Wedding    @map("Wedding")
  Birthday   @map("Birthday")
  BabyShower @map("Baby Shower")
  Other      @map("Other")
}

enum ListingStatus {
  Draft
  Published
  Closed
}

model Ribbon {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String  @db.Uuid

  type     RibbonType
  position Int        @default(0)
  name     String     @default("My Ribbon") @db.VarChar(255)
  styles   Json       @default("{}") @db.Json

  properties Json @default("{}") @db.Json
}

enum RibbonType {
  Banner
  Countdown
  CoverImage
  Embedded
  ImageCarousel
  ImageGallery
  Location
  RegistryShowcase
  Text
}

model Item {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  sku        String  @unique
  commerceId String? @db.VarChar(255)

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String  @db.Uuid

  description String?

  quantity Int @default(0)
  stock    Int @default(0)

  itemPurchases ItemPurchase[]
}

model Purchase {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  commerceId String? @db.VarChar(255)

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String  @db.Uuid

  paidAt DateTime?
  paid   Boolean   @default(false)

  total Float
  cost  Float

  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?   @db.Uuid

  note Note?

  itemPurchases ItemPurchase[]
}

model Note {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String  @db.Uuid

  purchase   Purchase? @relation(fields: [purchaseId], references: [id])
  purchaseId String?   @unique @db.Uuid

  type NoteType

  text     String?
  imageUrl String?
  audioUrl String?
  videoUrl String?
}

enum NoteType {
  Text
  Image
  Audio
  Video
}

model ItemPurchase {
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  item   Item   @relation(fields: [itemId], references: [id])
  itemId String @db.Uuid

  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  purchaseId String   @db.Uuid

  total Float
  cost  Float

  quantity Int

  @@id([itemId, purchaseId])
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  firstName String
  lastName  String
  email     String  @unique
  phone     String?

  role        UserRole  @default(User)
  lastLoginAt DateTime?

  listings Listing[]
  images   Image[]
  assets   Asset[]
}

enum UserRole {
  Admin
  User
}

model Image {
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  id       String @id // The image id from the service
  filename String

  user   User   @relation(fields: [userId], references: [id])
  userId String @db.Uuid
}

model Asset {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  service StorageService
  bucket  String

  name     String // The user defined name
  mimeType String
  filename String // The original filename
  size     Int // In bytes

  url String @unique

  user    User   @relation(fields: [ownerId], references: [id])
  ownerId String @db.Uuid
}

enum StorageService {
  R2
}

model ScrapedProduct {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  url String

  time     Float
  duration Float
  errors   String[]

  title       String?
  store       String?
  description String?
  image       String?
  amount      Float?
  currency    String?
}

model Customer {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  email String  @unique
  name  String?

  alegraId   String?
  commerceId String? @db.VarChar(255)

  purchase Purchase[]
}

model Webhook {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  service   WebhookService
  webhookId String

  event String

  payload Json? @db.Json
}

enum WebhookService {
  Shopify
}

model Checkout {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  commerceId String? @unique @db.VarChar(255)

  completedAt DateTime?

  name  String?
  email String?
  phone String?

  notified Boolean @default(false)
}
