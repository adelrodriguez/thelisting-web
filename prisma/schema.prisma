generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Listing {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  closedAt    DateTime?
  publishedAt DateTime?

  sku        Int     @default(autoincrement())
  commerceId String? @db.VarChar(255)

  eventDate DateTime
  path      String        @unique @db.VarChar(255)
  status    ListingStatus @default(Draft)
  title     String        @db.VarChar(255)
  type      ListingType   @default(Wedding)

  owner   User   @relation(fields: [ownerId], references: [id])
  ownerId String @db.Uuid

  items     Item[]
  purchases Purchase[]
  notes     Note[]
  ribbons   Ribbon[]
}

enum ListingType {
  Wedding    @map("Wedding")
  Birthday   @map("Birthday")
  BabyShower @map("Baby Shower")
  Other      @map("Other")
}

enum ListingStatus {
  Draft
  Published
  Closed
}

model Ribbon {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String  @db.Uuid

  type     RibbonType
  position Int        @default(0)

  properties Json @default("{}") @db.Json
}

enum RibbonType {
  Banner
}

model Item {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  commerceId String? @db.VarChar(255)

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String  @db.Uuid

  description String?

  quantity Int @default(0)
  stock    Int @default(0)

  itemPurchases ItemPurchase[]
}

model Purchase {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  commerceId String? @db.VarChar(255)

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String  @db.Uuid

  amount Float

  note Note?

  itemPurchases ItemPurchase[]
}

model Note {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  listing   Listing @relation(fields: [listingId], references: [id])
  listingId String  @db.Uuid

  purchase   Purchase? @relation(fields: [purchaseId], references: [id])
  purchaseId String?   @unique @db.Uuid

  type NoteType

  text     String?
  imageUrl String?
  audioUrl String?
  videoUrl String?
}

enum NoteType {
  Text
  Image
  Audio
  Video
}

model ItemPurchase {
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  item   Item   @relation(fields: [itemId], references: [id])
  itemId String @db.Uuid

  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  purchaseId String   @db.Uuid

  quantity Int

  @@id([itemId, purchaseId])
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  firstName String
  lastName  String
  email     String @unique

  role        UserRole  @default(User)
  lastLoginAt DateTime?

  listings Listing[]
}

enum UserRole {
  Admin
  User
}

model ScrapedProduct {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  url String

  time     Float
  duration Float
  errors   String[]

  title       String?
  store       String?
  description String?
  image       String?
  amount      Float?
  currency    String?
}

model Customer {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  email String @unique

  alegraId String
}

model Webhook {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  service   WebhookService
  webhookId String

  event String

  payload Json? @db.Json
}

enum WebhookService {
  Shopify
}
